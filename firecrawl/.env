# No versioned tags on ghcr.io — :latest only
# https://github.com/mendableai/firecrawl/releases
FIRECRAWL_IMAGE=ghcr.io/firecrawl/firecrawl:latest
PLAYWRIGHT_IMAGE=ghcr.io/firecrawl/playwright-service:latest

PORT=21000
INTERNAL_PORT=3002

# POSTGRES_USER and POSTGRES_DB must stay "postgres" — nuq-postgres initialises pg_cron against that role
POSTGRES_USER=postgres
POSTGRES_PASSWORD=aaa7a4dd3b08404818f7f844d79cee2cd89420ae95645a0008929491afce6188
POSTGRES_DB=postgres

# Queue UI: http://<host>:21000/admin/<BULL_AUTH_KEY>/queues
BULL_AUTH_KEY=64615a1ca0073b2df71e89011d5f179fc535636c33cebaaf82ea4af7cdd5dc7f

USE_DB_AUTHENTICATION=false

NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

LOGGING_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
MODEL_EMBEDDING_NAME=

PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
BLOCK_MEDIA=

SEARXNG_ENDPOINT=
SEARXNG_ENGINES=
SEARXNG_CATEGORIES=

SELF_HOSTED_WEBHOOK_URL=
