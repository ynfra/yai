        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({model: 'openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free', input: $json.texts}) }}",
