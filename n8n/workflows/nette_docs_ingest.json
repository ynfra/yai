    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst md = (item.data && item.data.markdown) ? item.data.markdown : '';\nconst url = (item.data && item.data.metadata && item.data.metadata.sourceURL) ? item.data.metadata.sourceURL : '';\nconst title = (item.data && item.data.metadata && item.data.metadata.title) ? item.data.metadata.title : url;\nif (!md || md.length < 50) {\n  return [{ json: { skip: true, url, title, chunks: [], texts: [] } }];\n}\nconst sections = md.split(/\\n(?=#{1,3} )/).map(s => s.trim()).filter(s => s.length > 80);\nconst raw = sections.length > 0 ? sections : [md];\nconst chunks = raw.map((text, i) => ({ text: text.substring(0, 2000), chunk_index: i }));\nconst texts = chunks.map(c => c.text);\nreturn [{ json: { skip: false, url, title, chunks, texts } }];"
      },
