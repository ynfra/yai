      "id": "ni-07",
      "name": "LiteLLM Embed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        544,
        -208
      ],
      "credentials": {
        "openAiApi": {
          "id": "7SoM6ZsaObayRno9",
          "name": "yai-litellm"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst embedResp = $input.first().json;\nconst embedData = embedResp.data || [];\nconst chunkData = $('Chunk + Prepare').item.json;\nconst chunks = chunkData.chunks;\nconst url = chunkData.url;\nconst title = chunkData.title;\nconst crawledAt = new Date().toISOString();\nif (!embedData.length || !chunks.length) {\n  return [{ json: { points: [] } }];\n}\nconst points = embedData.map(emb => {\n  const chunk = chunks[emb.index] || chunks[0];\n  const h = crypto.createHash('md5').update(url + ':' + chunk.chunk_index).digest('hex');\n  const uuid = h.slice(0,8)+'-'+h.slice(8,12)+'-'+h.slice(12,16)+'-'+h.slice(16,20)+'-'+h.slice(20,32);\n  return {\n    id: uuid,\n    vector: emb.embedding,\n    payload: { text: chunk.text, url, title, chunk_index: chunk.chunk_index, crawled_at: crawledAt }\n  };\n});\nreturn [{ json: { points } }];"
      },
