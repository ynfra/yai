      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst d = resp.data || {};\nconst meta = d.metadata || {};\nreturn [{ json: {\n  text: d.markdown || '',\n  metadata: {\n    url: meta.sourceURL || meta.url || '',\n    title: meta.title || 'Untitled',\n    scraped_at: new Date().toISOString()\n  }\n} }];"
