    {
      "parameters": {
        "jsCode": "const allLinks = [];\nfor (const item of $input.all()) {\n  const links = item.json.links || [];\n  allLinks.push(...links);\n}\n\nconst seen = new Set();\nconst result = [];\nfor (const url of allLinks) {\n  if (seen.has(url)) continue;\n  seen.add(url);\n\n  // Skip anchor URLs\n  if (url.includes('#')) continue;\n\n  // doc.nette.org: English (/en/) only\n  if (url.includes('doc.nette.org') && !/\\/en\\//.test(url)) continue;\n\n  // Only pages on target domains\n  if (!url.includes('doc.nette.org') && !url.includes('contributte.org')) continue;\n\n  result.push({ json: { url } });\n}\n\nreturn result;"
      },
      "id": "878e5128-9274-4a2c-8e04-59fe6a0eb0e0",
      "name": "Filter + Deduplicate",
      "type": "n8n-nodes-base.code",
