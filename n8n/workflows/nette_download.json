    {
      "parameters": {
        "jsCode": "const cutoff = Date.now() - 30 * 24 * 60 * 60 * 1000;\nreturn $input.all()\n  .filter(item => {\n    const d = item.json.pubDate ? new Date(item.json.pubDate).getTime() : 0;\n    return d >= cutoff;\n  })\n  .sort((a, b) => new Date(b.json.pubDate||0) - new Date(a.json.pubDate||0));"
      },
      "id": "nd-04",
      "name": "Filter & Sort",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        48,
        48
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "nd-05",
      "name": "Loop Articles",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        272,
        48
      ]
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst item = $input.first().json;\nconst link = item.link || '';\nconst guid = crypto.createHash('md5').update('nette:' + link).digest('hex');\nreturn [{ json: { guid, title: item.title||'', link, pubDate: item.pubDate||item.isoDate||null, contentSnippet: item.contentSnippet||item.content||'' } }];"
      },
      "id": "nd-06",
      "name": "Setup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        -96
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT (COUNT(*) = 0) AS is_new FROM rss_articles WHERE guid = '{{ $json.guid }}'",
        "options": {}
      },
      "id": "nd-07",
