      "id": "nd-08",
      "name": "New Article?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        944,
        -96
      ]
    },
    {
      "parameters": {
        "url": "={{ $('Setup').item.json.link }}",
        "options": {}
      },
      "id": "nd-09",
      "name": "Fetch Article",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1168,
        -96
      ]
    },
    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data || '';\nconst patterns = [/<article[\\s\\S]*?>([\\s\\S]*?)<\\/article>/i, /<main[\\s\\S]*?>([\\s\\S]*?)<\\/main>/i];\nlet content = '';\nfor (const re of patterns) {\n  const m = html.match(re);\n  if (m && m[1].trim().length > 100) { content = m[1]; break; }\n}\nif (!content) {\n  const b = html.match(/<body[\\s\\S]*?>([\\s\\S]*?)<\\/body>/i);\n  content = b ? b[1] : html;\n}\ncontent = content\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<!--[\\s\\S]*?-->/g, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim()\n  .substring(0, 10000);\nreturn [{ json: { text: content } }];"
      },
      "id": "nd-10",
      "name": "Extract Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1392,
        -96
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO rss_articles (guid, title, link, published_at, content, state) VALUES ('{{ $('Setup').item.json.guid }}', '{{ $('Setup').item.json.title.replace(/'/g, \"''\") }}', '{{ $('Setup').item.json.link.replace(/'/g, \"''\") }}', {{ $('Setup').item.json.pubDate ? \"'\" + $('Setup').item.json.pubDate + \"'\" : 'NULL' }}, '{{ $json.text.replace(/'/g, \"''\") }}', 'pending') ON CONFLICT (guid) DO NOTHING",
        "options": {}
      },
      "id": "nd-11",
      "name": "PG Insert",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
