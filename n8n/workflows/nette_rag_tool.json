    },
    {
      "id": "nrt-04",
      "name": "Format Passages + Sources",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        0
      ],
      "parameters": {
        "jsCode": "const docs = $input.all();\nif (!docs.length) {\n  return [{ json: { response: 'No relevant Nette documentation found for this query.' } }];\n}\nconst blocks = docs.map((d, i) => {\n  const doc = (d.json && d.json.document) || {};\n  const meta = doc.metadata || {};\n  const title = meta.title || 'Untitled';\n  const url = meta.url || '';\n  const content = (doc.pageContent || '').trim();\n  return `[${i + 1}] ${title}\\nSource: ${url}\\n\\n${content}`;\n});\nconst response = blocks.join('\\n\\n---\\n\\n');\nreturn [{ json: { response } }];"
      }
    }
  ],
  "connections": {
