{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": { "limit": 100, "matchAny": false, "tags": [], "type": "dashboard" },
        "type": "dashboard"
      }
    ]
  },
  "description": "PGSQL Queries Overview — top queries by call rate / latency, click through to PGSQL Query for detail. Top 30 tables are cumulative since pg_stat_statements stats_reset (no time bounds) and honour the User / Query Type filters; Trends panels honour the time picker only (pg_query_* metrics don't expose user / type labels).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["FX","PGSQL","Overview"], "targetBlank": false, "title": "Overview", "tooltip": "", "type": "dashboards", "url": "" },
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["FX","PGSQL","Cluster"], "targetBlank": false, "title": "Cluster", "tooltip": "", "type": "dashboards", "url": "" },
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["FX","PGSQL","Instance"], "targetBlank": false, "title": "Instance", "tooltip": "", "type": "dashboards", "url": "" },
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["FX","PGSQL","Database"], "targetBlank": false, "title": "Database", "tooltip": "", "type": "dashboards", "url": "" }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview — ${instance} / ${datname}",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VMETRICS}" },
      "description": "Total queries-per-second across all tracked queries.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "qps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true,
        "text": { "valueSize": 30 }
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VMETRICS}" },
          "expr": "sum(rate(pg_query_calls{instance=\"$instance\", datname=\"$datname\"}[1m]))",
          "legendFormat": "QPS",
          "refId": "A"
        }
      ],
      "title": "Total QPS",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VMETRICS}" },
      "description": "Mean response time across all tracked queries (last 1m).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.5 } ] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true,
        "text": { "valueSize": 30 }
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VMETRICS}" },
          "expr": "sum(rate(pg_query_exec_time{instance=\"$instance\", datname=\"$datname\"}[1m])) / sum(rate(pg_query_calls{instance=\"$instance\", datname=\"$datname\"}[1m]))",
          "legendFormat": "Mean RT",
          "refId": "A"
        }
      ],
      "title": "Mean RT",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VMETRICS}" },
