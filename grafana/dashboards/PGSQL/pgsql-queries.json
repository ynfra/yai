      "id": 12,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "Mean (ms)" } ]
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH s AS (SELECT ps.*, CASE WHEN ps.query ~* '^\\s*\\(*\\s*SELECT' THEN 'SELECT' WHEN ps.query ~* '^\\s*INSERT' THEN 'INSERT' WHEN ps.query ~* '^\\s*UPDATE' THEN 'UPDATE' WHEN ps.query ~* '^\\s*DELETE' THEN 'DELETE' WHEN ps.query ~* '^\\s*WITH' THEN 'WITH' WHEN ps.query ~* '^\\s*COPY' THEN 'COPY' WHEN ps.query ~* '^\\s*(CREATE|ALTER|DROP|TRUNCATE)' THEN 'DDL' WHEN ps.query ~* '^\\s*(BEGIN|COMMIT|ROLLBACK|SAVEPOINT|RELEASE)' THEN 'TX' WHEN ps.query ~* '^\\s*(VACUUM|ANALYZE|CLUSTER|REINDEX)' THEN 'MAINT' WHEN ps.query ~* '^\\s*(SET|SHOW|RESET)' THEN 'SESSION' WHEN ps.query ~* '^\\s*CALL' THEN 'CALL' ELSE 'OTHER' END AS qtype FROM pg_stat_statements ps) SELECT s.queryid::text AS queryid, COALESCE(r.rolname, s.userid::text) AS rolname, s.qtype, (sum(s.total_exec_time) / NULLIF(sum(s.calls),0))::float AS mean_ms, max(s.stddev_exec_time)::float AS stddev_ms, max(s.max_exec_time)::float AS max_ms, CASE WHEN sum(s.total_exec_time) > 0 THEN (100.0 * sum(s.shared_blk_read_time + s.shared_blk_write_time + s.temp_blk_read_time + s.temp_blk_write_time) / sum(s.total_exec_time))::float ELSE 0 END AS io_pct, sum(s.calls)::bigint AS calls, (sum(s.total_exec_time)/1000.0)::float AS total_s, sum(s.rows)::bigint AS rows, regexp_replace(left(s.query, 400), '\\s+', ' ', 'g') AS query FROM s JOIN pg_database d ON s.dbid = d.oid LEFT JOIN pg_roles r ON s.userid = r.oid WHERE d.datname = '${datname}' AND s.calls > 4 AND COALESCE(r.rolname, s.userid::text) = ANY(ARRAY[${user:sqlstring}]::text[]) AND s.qtype = ANY(ARRAY[${qtype:sqlstring}]::text[]) GROUP BY s.queryid, s.query, r.rolname, s.userid, s.qtype ORDER BY mean_ms DESC LIMIT 30",
          "refId": "A",
          "sql": { "columns": [], "groupBy": [], "limit": 50 }
        }
      ],
      "title": "Top 30 Queries (by mean time)",
      "type": "table"
    },
