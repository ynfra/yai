      },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 25 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "Calls" } ]
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH s AS (SELECT ps.*, CASE WHEN ps.query ~* '^\\s*\\(*\\s*SELECT' THEN 'SELECT' WHEN ps.query ~* '^\\s*INSERT' THEN 'INSERT' WHEN ps.query ~* '^\\s*UPDATE' THEN 'UPDATE' WHEN ps.query ~* '^\\s*DELETE' THEN 'DELETE' WHEN ps.query ~* '^\\s*WITH' THEN 'WITH' WHEN ps.query ~* '^\\s*COPY' THEN 'COPY' WHEN ps.query ~* '^\\s*(CREATE|ALTER|DROP|TRUNCATE)' THEN 'DDL' WHEN ps.query ~* '^\\s*(BEGIN|COMMIT|ROLLBACK|SAVEPOINT|RELEASE)' THEN 'TX' WHEN ps.query ~* '^\\s*(VACUUM|ANALYZE|CLUSTER|REINDEX)' THEN 'MAINT' WHEN ps.query ~* '^\\s*(SET|SHOW|RESET)' THEN 'SESSION' WHEN ps.query ~* '^\\s*CALL' THEN 'CALL' ELSE 'OTHER' END AS qtype FROM pg_stat_statements ps) SELECT s.queryid::text AS queryid, COALESCE(r.rolname, s.userid::text) AS rolname, s.qtype, sum(s.calls)::bigint AS calls, (sum(s.calls) / GREATEST(EXTRACT(EPOCH FROM (now() - i.stats_reset)), 1))::float AS qps, (sum(s.total_exec_time) / NULLIF(sum(s.calls),0))::float AS mean_ms, (sum(s.total_exec_time)/1000.0)::float AS total_s, sum(s.rows)::bigint AS rows, regexp_replace(left(s.query, 400), '\\s+', ' ', 'g') AS query FROM s JOIN pg_database d ON s.dbid = d.oid LEFT JOIN pg_roles r ON s.userid = r.oid CROSS JOIN pg_stat_statements_info i WHERE d.datname = '${datname}' AND s.calls > 4 AND COALESCE(r.rolname, s.userid::text) = ANY(ARRAY[${user:sqlstring}]::text[]) AND s.qtype = ANY(ARRAY[${qtype:sqlstring}]::text[]) GROUP BY s.queryid, s.query, r.rolname, s.userid, s.qtype, i.stats_reset ORDER BY calls DESC LIMIT 30",
          "refId": "A",
          "sql": { "columns": [], "groupBy": [], "limit": 50 }
        }
      ],
      "title": "Top 30 Queries (by calls)",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "description": "Top 30 queries by mean execution time (live from pg_stat_statements, grouped by queryid + user). Mean = total/calls. Stddev shows plan stability (high stddev → unstable plan). I/O% = share of mean spent in shared+temp block read/write (track_io_timing=on). Cumulative since stats_reset — not bound by time picker. Click any Query ID to open the detail dashboard.",
      "fieldConfig": {
