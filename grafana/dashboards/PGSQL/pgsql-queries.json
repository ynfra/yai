        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "Total (s)" } ]
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH s AS (SELECT ps.*, CASE WHEN ps.query ~* '^\\s*\\(*\\s*SELECT' THEN 'SELECT' WHEN ps.query ~* '^\\s*INSERT' THEN 'INSERT' WHEN ps.query ~* '^\\s*UPDATE' THEN 'UPDATE' WHEN ps.query ~* '^\\s*DELETE' THEN 'DELETE' WHEN ps.query ~* '^\\s*WITH' THEN 'WITH' WHEN ps.query ~* '^\\s*COPY' THEN 'COPY' WHEN ps.query ~* '^\\s*(CREATE|ALTER|DROP|TRUNCATE)' THEN 'DDL' WHEN ps.query ~* '^\\s*(BEGIN|COMMIT|ROLLBACK|SAVEPOINT|RELEASE)' THEN 'TX' WHEN ps.query ~* '^\\s*(VACUUM|ANALYZE|CLUSTER|REINDEX)' THEN 'MAINT' WHEN ps.query ~* '^\\s*(SET|SHOW|RESET)' THEN 'SESSION' WHEN ps.query ~* '^\\s*CALL' THEN 'CALL' ELSE 'OTHER' END AS qtype FROM pg_stat_statements ps), t AS ( SELECT s.queryid, s.query, COALESCE(r.rolname, s.userid::text) AS rolname, s.qtype, sum(s.total_exec_time) AS total_ms, sum(s.shared_blk_read_time + s.shared_blk_write_time + s.temp_blk_read_time + s.temp_blk_write_time) AS io_ms, sum(s.calls) AS calls, sum(s.rows) AS rows, sum(s.wal_bytes) AS wal_bytes, sum(s.temp_blks_written) AS temp_blks_written FROM s JOIN pg_database d ON s.dbid = d.oid LEFT JOIN pg_roles r ON s.userid = r.oid WHERE d.datname = '${datname}' AND s.calls > 4 AND COALESCE(r.rolname, s.userid::text) = ANY(ARRAY[${user:sqlstring}]::text[]) AND s.qtype = ANY(ARRAY[${qtype:sqlstring}]::text[]) GROUP BY s.queryid, s.query, r.rolname, s.userid, s.qtype ), tot AS ( SELECT NULLIF(sum(total_ms), 0) AS total_ms_all FROM t ) SELECT t.queryid::text AS queryid, t.rolname, t.qtype, (t.total_ms / 1000.0)::float AS total_s, (t.io_ms / 1000.0)::float AS io_s, CASE WHEN t.total_ms > 0 THEN (100.0 * t.io_ms / t.total_ms)::float ELSE 0 END AS io_pct, (100.0 * t.total_ms / tot.total_ms_all)::float AS share_pct, t.calls::bigint AS calls, (t.wal_bytes / 1024.0 / 1024.0)::float AS wal_mb, ((t.temp_blks_written * 8192.0) / 1024.0 / 1024.0)::float AS temp_mb, t.rows::bigint AS rows, regexp_replace(left(t.query, 400), '\\s+', ' ', 'g') AS query FROM t CROSS JOIN tot ORDER BY total_s DESC LIMIT 30",
          "refId": "A",
          "sql": { "columns": [], "groupBy": [], "limit": 50 }
        }
      ],
