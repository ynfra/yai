    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "description": "Top 30 queries by call count (live from pg_stat_statements, grouped by queryid + user). Cumulative since stats_reset — not bound by time picker. Click any Query ID to open the detail dashboard.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto", "wrapText": false },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "queryid" },
            "properties": [
              { "id": "displayName", "value": "Query ID" },
              { "id": "custom.width", "value": 220 },
              { "id": "links", "value": [ { "title": "PGSQL Query : ${__data.fields.queryid}", "url": "/d/pgsql-query?var-instance=${instance}&var-datname=${datname}&var-query=${__data.fields.queryid}&${__url_time_range}" } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rolname" },
            "properties": [
              { "id": "displayName", "value": "User" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "qtype" },
            "properties": [
              { "id": "displayName", "value": "Type" },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "calls" },
            "properties": [
              { "id": "displayName", "value": "Calls" },
              { "id": "custom.width", "value": 110 },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "qps" },
            "properties": [
              { "id": "displayName", "value": "QPS (avg)" },
              { "id": "custom.width", "value": 110 },
              { "id": "unit", "value": "qps" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mean_ms" },
            "properties": [
              { "id": "displayName", "value": "Mean (ms)" },
              { "id": "custom.width", "value": 110 },
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 500 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_s" },
            "properties": [
              { "id": "displayName", "value": "Total Time (s)" },
              { "id": "custom.width", "value": 130 },
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rows" },
            "properties": [
              { "id": "displayName", "value": "Rows" },
              { "id": "custom.width", "value": 110 },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "query" },
            "properties": [
              { "id": "displayName", "value": "SQL" },
              { "id": "custom.cellOptions", "value": { "type": "auto", "wrapText": true } }
