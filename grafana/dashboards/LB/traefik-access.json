          "editorMode": "code",
          "expr": "log_kind:traefik_access service:~\"${service:regex}\" | stats count() if (status_class:=\"4xx\") as e4, count() if (status_class:=\"5xx\") as e5, count() as total | math (e4 + e5) / total * 100 as pct | fields pct",
          "queryType": "stats",
